@model WebBanHang.Models.ApplicationUser
@{
    var display = Model?.FullName;
    if (string.IsNullOrWhiteSpace(display))
    {
        display = Model?.UserName ?? Model?.Email ?? "Tài khoản";
    }
    var initial = display.Length > 0 ? display.Substring(0, 1).ToUpperInvariant() : "?";
}
<div class="dropdown c-user-dropdown">
    <button class="c-avatar c-avatar--btn" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="@display">
        @initial
    </button>
    <ul class="dropdown-menu dropdown-menu-end c-dropdown-menu shadow border">
        <li class="px-3 py-2 border-bottom">
            <div class="fw-semibold c-dropdown-name">@display</div>
            <div class="small c-dropdown-email text-truncate" style="max-width: 220px;">@(Model?.Email ?? "")</div>
        </li>
        <li>
            <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                <i class="bi bi-person-gear me-2"></i>Thông tin tài khoản
            </a>
        </li>
        <li><hr class="dropdown-divider" /></li>
        <li>
            <form asp-controller="Account" asp-action="Logout" method="post" class="px-2 pb-1">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                    <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                </button>
            </form>
        </li>
    </ul>
</div>
