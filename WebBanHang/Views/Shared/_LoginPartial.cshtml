@using Microsoft.AspNetCore.Identity
@using WebBanHang.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline"
                asp-area="Identity"
                asp-page="/Account/Logout"
                asp-route-returnUrl="@Url.Page("/Account/Login", new { area = "Identity" })">
            <button type="submit" class="nav-link btn btn-link text-white">
                <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
            </button>
        </form>
    </li>

}
else
{
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Register">
            <i class="bi bi-person-plus me-1"></i>Đăng ký
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Login">
            <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập
        </a>
    </li>
}
</ul>
