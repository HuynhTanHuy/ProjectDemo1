@model WebBanHang.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-4 p-md-5">
                    <h3 class="text-center fw-bold mb-4">Welcome back</h3>
                    <form method="post" asp-action="Login">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <div class="mb-3">
                            <label asp-for="UserNameOrEmail" class="form-label"></label>
                            <input asp-for="UserNameOrEmail" class="form-control form-control-lg rounded-3" />
                            <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control form-control-lg rounded-3" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="form-check mb-3">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label"></label>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 rounded-3" id="loginBtn">Login</button>
                    </form>
                    <p class="text-center mt-3 mb-0">
                        No account?
                        <a asp-action="Register">Create one</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const form = document.querySelector('form');
            const btn = document.getElementById('loginBtn');
            if (!form || !btn) return;
            form.addEventListener('input', () => {
                btn.disabled = !form.checkValidity();
            });
            btn.disabled = !form.checkValidity();
        })();
    </script>
}
