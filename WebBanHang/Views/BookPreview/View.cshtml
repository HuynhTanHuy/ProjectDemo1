@model WebBanHang.Models.ViewModels.BookPreviewViewModel
@{
    Layout = "~/Areas/Customer/Views/Shared/_LayoutCustomer.cshtml";
    ViewData["Title"] = ViewData["Title"] as string ?? "Đọc thử";
}

@await Html.PartialAsync("~/Areas/Customer/Views/Shared/_CustomerSubnav.cshtml", "products")

<div class="container mt-4 c-browse-page">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <h1 class="h4 mb-0">Đọc thử</h1>
        <a asp-area="Customer" asp-controller="Product" asp-action="Details" asp-route-id="@Model.BookId" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Quay lại chi tiết sách
        </a>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: var(--radius, 12px);">
        <div class="card-body">
            <p class="small text-secondary mb-3">
                Số trang xem thử: <strong>@Model.PreviewPages</strong> / <strong>@Model.TotalPages</strong>
            </p>

            @if (Model.PreviewType == WebBanHang.Models.PreviewType.Pdf)
            {
                <iframe src="/BookPreview/Stream/@Model.BookId" title="PDF đọc thử" width="100%" height="600" class="rounded border"></iframe>
            }
            else
            {
                <div class="preview-text-content">
                    @Html.Raw(Model.Content)
                </div>
            }

            @if (Model.PreviewType == WebBanHang.Models.PreviewType.Pdf && Model.AllowDownload)
            {
                <div class="mt-3">
                    <a class="btn btn-primary" href="/BookPreview/Stream/@Model.BookId" target="_blank" rel="noopener">
                        <i class="bi bi-download me-1"></i>Tải bản xem thử
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const startedAt = Date.now();
            const payload = new URLSearchParams();
            payload.append("bookId", "@Model.BookId");

            const sendLog = () => {
                const seconds = Math.max(1, Math.floor((Date.now() - startedAt) / 1000));
                payload.set("durationSeconds", seconds.toString());
                navigator.sendBeacon("/BookPreview/Log", payload);
            };

            window.addEventListener("beforeunload", sendLog);
        })();
    </script>
}
