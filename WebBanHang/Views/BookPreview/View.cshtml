@model WebBanHang.Models.ViewModels.BookPreviewViewModel

@{
    ViewData["Title"] = "Book Preview";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Book Preview</h3>
        <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="mb-3 text-muted">
                Preview pages: <strong>@Model.PreviewPages</strong> / <strong>@Model.TotalPages</strong>
            </div>

            @if (Model.PreviewType == WebBanHang.Models.PreviewType.Pdf)
            {
                <iframe src="/BookPreview/Stream/@Model.BookId" width="100%" height="600px"></iframe>
            }
            else
            {
                <div>
                    @Html.Raw(Model.Content)
                </div>
            }

            @if (Model.PreviewType == WebBanHang.Models.PreviewType.Pdf && Model.AllowDownload)
            {
                <div class="mt-3">
                    <a class="btn btn-primary" href="/BookPreview/Stream/@Model.BookId" target="_blank" rel="noopener">Download preview</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const startedAt = Date.now();
            const payload = new URLSearchParams();
            payload.append("bookId", "@Model.BookId");

            const sendLog = () => {
                const seconds = Math.max(1, Math.floor((Date.now() - startedAt) / 1000));
                payload.set("durationSeconds", seconds.toString());
                navigator.sendBeacon("/BookPreview/Log", payload);
            };

            window.addEventListener("beforeunload", sendLog);
        })();
    </script>
}
