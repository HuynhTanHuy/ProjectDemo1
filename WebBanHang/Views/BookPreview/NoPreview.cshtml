@{
    ViewData["Title"] = "No Preview";
    var bookId = ViewBag.BookId;
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <h3 class="mb-3">Chưa có bản xem thử</h3>
            <p class="text-muted mb-4">
                Sách có mã <strong>@bookId</strong> hiện chưa được cấu hình nội dung preview.
            </p>
            <a asp-area="Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary">
                Quay về danh sách sách
            </a>
        </div>
    </div>
</div>
