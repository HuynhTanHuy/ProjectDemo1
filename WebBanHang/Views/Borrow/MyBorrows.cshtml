@model IEnumerable<WebBanHang.Models.Borrow>
@{
    ViewData["Title"] = "Sách tôi đang mượn";
}

<div class="container mt-4">
    <h3 class="mb-3">Sách tôi đang mượn</h3>
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Sách</th>
                        <th>Ngày mượn</th>
                        <th>Hạn trả</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Book?.Name</td>
                        <td>@item.BorrowDate.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>@item.DueDate.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (item.Status == WebBanHang.Models.BorrowStatus.Borrowing)
                            {
                                <span class="badge bg-warning text-dark">Đang mượn</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Đã trả</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (item.Status == WebBanHang.Models.BorrowStatus.Borrowing)
                            {
                                <form asp-action="ReturnBook" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="borrowId" value="@item.Id" />
                                    <button class="btn btn-sm btn-primary rounded-pill">Trả sách</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
