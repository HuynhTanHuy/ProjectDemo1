@model IEnumerable<WebBanHang.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Categories</h2>
        <a asp-action="Add" class="btn btn-primary">Add New Category</a>
    </div>

    <div class="row">
        @foreach (var category in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@category.Name</h5>
                        <p class="card-text">Products: @(category.Products?.Count ?? 0)</p>
                        <div class="d-flex justify-content-between">
                            <a asp-action="Display" asp-route-id="@category.Id" class="btn btn-info">View</a>
                            <a asp-action="Update" asp-route-id="@category.Id" class="btn btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-danger">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div> 