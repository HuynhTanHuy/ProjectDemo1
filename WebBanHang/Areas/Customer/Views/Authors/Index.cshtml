@model IEnumerable<WebBanHang.Models.Author>
@await Html.PartialAsync("_CustomerSubnav", "authors")

<div class="c-browse-page">
    <header class="c-page-head">
        <div>
            <h1 class="c-page-head__title"><i class="bi bi-people me-2"></i>Tác giả</h1>
            <p class="c-page-head__sub">Danh sách tác giả trong hệ thống</p>
        </div>
        <a class="c-btn-ghost" href="@Url.RouteUrl("customerAuthorBrowser", new { action = "Index" })">
            <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
        </a>
    </header>

    <div class="c-tiles">
        @if (Model != null && Model.Any())
        {
            @foreach (var a in Model)
            {
                <a class="c-tile" asp-area="Customer" asp-controller="Authors" asp-action="Details" asp-route-id="@a.Id">
                    @if (!string.IsNullOrEmpty(a.PhotoUrl))
                    {
                        <div class="c-tile__media">
                            <img src="@a.PhotoUrl" alt="" loading="lazy" />
                        </div>
                    }
                    else
                    {
                        <div class="c-tile__media c-tile__media--icon"><i class="bi bi-person-circle"></i></div>
                    }
                    <h3>@a.Name</h3>
                    @if (!string.IsNullOrEmpty(a.Biography))
                    {
                        <p class="text-truncate">@a.Biography</p>
                    }
                </a>
            }
        }
        else
        {
            <div class="c-empty">Không có tác giả nào.</div>
        }
    </div>

    <div class="mt-4">
        @await Html.PartialAsync("_Pagination")
    </div>
</div>
