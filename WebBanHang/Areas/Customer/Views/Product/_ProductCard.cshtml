@using System.Globalization
@model WebBanHang.Models.Product

<div class="card h-100 c-product-card">
    <div class="position-relative">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Name" style="height: 220px; object-fit: cover;">
        }
        else
        {
            <img src="/images/no-image.jpg" class="card-img-top" alt="No Image" style="height: 220px; object-fit: cover;">
        }
        <div class="position-absolute top-0 end-0 m-2">
            @if (Model.DiscountPercent.HasValue && Model.DiscountPercent.Value > 0)
            {
                <span class="badge bg-danger">-@Model.DiscountPercent%</span>
            }
        </div>
    </div>
    <div class="card-body d-flex flex-column">
        <h6 class="text-muted mb-1">@Model.Author?.Name</h6>
        <h5 class="card-title text-truncate">@Model.Name</h5>
        <div class="mb-2 small text-secondary">@Model.Genre?.Name · @Model.Language</div>
        <div class="mt-auto d-flex justify-content-between align-items-center">
            <div>
                <span class="text-danger fw-bold">@Model.Price.ToString("c", new CultureInfo("vi-VN"))</span>
            </div>
            <div class="btn-group flex-wrap" role="group">
                <a asp-area="Customer" asp-controller="Product" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-eye me-1"></i>Chi tiết
                </a>
                @if (Model.Stock > 0)
                {
                    <a asp-area="Customer" asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@Model.Id" asp-route-quantity="1" class="btn btn-primary btn-sm">
                        <i class="bi bi-cart-plus me-1"></i>Giỏ
                    </a>
                }
            </div>
        </div>
    </div>
</div>



