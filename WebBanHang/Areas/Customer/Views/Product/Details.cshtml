@using System.Globalization
@model WebBanHang.Models.Product
@functions {
    private static string T(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value!;
    private bool ShowReservePlace() => ViewBag.ShowReservePlace as bool? == true;
}
@await Html.PartialAsync("_CustomerSubnav", "products")

<div class="container mt-4 c-browse-page">
    <div class="mb-3">
        <a href="@Url.Action("Index", "Home", new { area = "Customer", tab = "products" })" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách sản phẩm
        </a>
    </div>

    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home", new { area = "Customer", tab = "products" })" class="text-decoration-none">Sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="card shadow border-0">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Name" style="width: 100%; max-height: 500px; object-fit: cover;">
                        }
                        else
                        {
                            <img src="/images/no-image.jpg" class="img-fluid rounded" alt="Không có ảnh" style="width: 100%; max-height: 500px; object-fit: cover;">
                        }
                        <div class="position-absolute top-0 end-0 m-3 d-flex flex-wrap gap-2 justify-content-end" style="max-width: 100%;">
                            <span class="badge bg-primary">@T(Model.Category?.Name)</span>
                            <span class="badge bg-secondary">@T(Model.Language)</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex flex-column h-100">
                        <h2 class="mb-1">@Model.Name</h2>
                        <div class="text-secondary mb-3 small">
                            <span class="text-body-secondary">Tác giả:</span> @T(Model.Author?.Name)
                            <span class="mx-1">·</span>
                            <span class="text-body-secondary">ISBN:</span> @T(Model.Isbn)
                        </div>
                        <div class="mb-4">
                            @if (Model.Stock > 0)
                            {
                                <span class="badge bg-success me-2">Còn hàng</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark me-2">Hết hàng</span>
                            }
                            <span class="text-muted">Mã SP: #@Model.Id</span>
                        </div>
                        <div>
                            @if (Model.DiscountPercent is > 0)
                            {
                                var oldPrice = Model.Price;
                                var newPrice = Model.Price * (100 - Model.DiscountPercent!.Value) / 100;

                                <span class="text-muted text-decoration-line-through me-2" style="font-size: 26px">
                                    @oldPrice.ToString("c", new CultureInfo("vi-VN"))
                                </span>

                                <span class="text-danger fw-bold" style="font-size: 26px">
                                    @newPrice.ToString("c", new CultureInfo("vi-VN"))
                                </span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold" style="font-size: 26px">
                                    @Model.Price.ToString("c", new CultureInfo("vi-VN"))
                                </span>
                            }
                        </div>
                        <div class="mb-4 small text-secondary">
                            <span class="text-body-secondary">NXB:</span> @T(Model.Publisher?.Name)
                            @if (Model.PublicationDate.HasValue)
                            {
                                <span class="mx-1">·</span><span>@Model.PublicationDate.Value.ToString("dd/MM/yyyy")</span>
                            }
                            else
                            {
                                <span class="mx-1">·</span><span>—</span>
                            }
                            @if (Model.PageCount.HasValue)
                            {
                                <span class="mx-1">·</span><span>@Model.PageCount trang</span>
                            }
                            else
                            {
                                <span class="mx-1">·</span><span>—</span>
                            }
                        </div>
                        <p class="mb-4">@(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả cho sách này." : Model.Description)</p>
                        <div class="mt-auto">
                            <div class="d-flex flex-wrap gap-2">
                                <form asp-area="" asp-controller="Borrow" asp-action="BorrowBook" method="post" class="d-inline-flex">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="bookId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-success" @(Model.Stock <= 0 ? "disabled" : null)>
                                        <i class="bi bi-journal-check me-2"></i>Mượn sách
                                    </button>
                                </form>
                                @if (Model.Stock > 0)
                                {
                                    <a asp-area="Customer" asp-controller="ShoppingCart" asp-action="AddToCart"
                                       asp-route-productId="@Model.Id" asp-route-quantity="1"
                                       class="btn btn-primary">
                                        <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ hàng
                                    </a>
                                }
                                else if (ShowReservePlace())
                                {
                                    <a asp-area="Customer" asp-controller="ShoppingCart" asp-action="AddToCart"
                                       asp-route-productId="@Model.Id" asp-route-quantity="1"
                                       class="btn btn-primary">
                                        <i class="bi bi-bookmark-plus me-2"></i>Đặt chỗ
                                    </a>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-primary" disabled title="Hiện không còn bản tại shop và chưa mở đặt chỗ cho đầu sách này.">
                                        <i class="bi bi-cart-plus me-2"></i>Thêm vào giỏ hàng
                                    </button>
                                }
                                <a asp-controller="BookPreview" asp-action="View" asp-route-bookId="@Model.Id"
                                   class="btn btn-outline-info"
                                   target="_blank" rel="noopener"
                                   title="@(ViewBag.HasBookPreview == true ? "Có bản đọc thử" : "Chưa cấu hình đọc thử — vẫn mở trang kiểm tra")">
                                    <i class="bi bi-book-half me-1"></i>Đọc thử
                                </a>
                                <button type="button" class="btn btn-outline-primary" id="btn-heart" aria-label="Yêu thích">
                                    <i class="bi bi-heart" id="icon-heart"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow border-0">
                <div class="card-body">
                    <ul class="nav nav-tabs" id="productTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="description-tab" data-bs-toggle="tab" data-bs-target="#description" type="button" role="tab">
                                <i class="bi bi-info-circle me-2"></i>Mô tả
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="specs-tab" data-bs-toggle="tab" data-bs-target="#specs" type="button" role="tab">
                                <i class="bi bi-gear me-2"></i>Thông số kỹ thuật
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews" type="button" role="tab">
                                <i class="bi bi-star me-2"></i>Đánh giá
                            </button>
                        </li>
                    </ul>
                    <div class="tab-content mt-3" id="productTabsContent">
                        <div class="tab-pane fade show active" id="description" role="tabpanel">
                            <p class="mb-0">@(string.IsNullOrWhiteSpace(Model.Description) ? "Chưa có mô tả cho sách này." : Model.Description)</p>
                        </div>
                        <div class="tab-pane fade" id="specs" role="tabpanel">
                            <table class="table table-sm mb-0">
                                <tbody>
                                    <tr>
                                        <th class="w-25">Danh mục</th>
                                        <td>@T(Model.Category?.Name)</td>
                                    </tr>
                                    <tr>
                                        <th>Tác giả</th>
                                        <td>@T(Model.Author?.Name)</td>
                                    </tr>
                                    <tr>
                                        <th>Thể loại</th>
                                        <td>@T(Model.Genre?.Name)</td>
                                    </tr>
                                    <tr>
                                        <th>Nhà xuất bản</th>
                                        <td>@T(Model.Publisher?.Name)</td>
                                    </tr>
                                    <tr>
                                        <th>ISBN</th>
                                        <td>@T(Model.Isbn)</td>
                                    </tr>
                                    <tr>
                                        <th>Giá</th>
                                        <td>@Model.Price.ToString("c", new CultureInfo("vi-VN"))</td>
                                    </tr>
                                    <tr>
                                        <th>Ngôn ngữ</th>
                                        <td>@T(Model.Language)</td>
                                    </tr>
                                    <tr>
                                        <th>Số trang</th>
                                        <td>@(Model.PageCount?.ToString() ?? "—")</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="tab-pane fade" id="reviews" role="tabpanel">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-action="AddReview" method="post" class="mb-4">
                                    <input type="hidden" name="productId" value="@Model.Id" />
                                    <div class="row g-2 align-items-center">
                                        <div class="col-12 col-md-2">
                                            <select name="rating" class="form-select">
                                                <option value="5">5 ★</option>
                                                <option value="4">4 ★</option>
                                                <option value="3">3 ★</option>
                                                <option value="2">2 ★</option>
                                                <option value="1">1 ★</option>
                                            </select>
                                        </div>
                                        <div class="col-12 col-md-8">
                                            <input type="text" name="comment" class="form-control" placeholder="Viết nhận xét..." />
                                        </div>
                                        <div class="col-12 col-md-2">
                                            <button class="btn btn-primary w-100" type="submit">Gửi</button>
                                        </div>
                                    </div>
                                </form>
                            }

                            @if (Model.Reviews != null && Model.Reviews.Any())
                            {
                                foreach (var r in Model.Reviews.OrderByDescending(x => x.CreatedAt))
                                {
                                    <div class="border rounded p-3 mb-3">
                                        <div class="d-flex justify-content-between">
                                            <strong>@(r.User?.UserName ?? "Ẩn danh")</strong>
                                            <span class="text-warning">@(new string('★', r.Rating))@(new string('☆', 5 - r.Rating))</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(r.Comment))
                                        {
                                            <div class="mt-2">@r.Comment</div>
                                        }
                                        <div class="text-muted small mt-2">@r.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center text-muted py-3">Chưa có đánh giá</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('button[data-bs-toggle="tab"]').forEach(function (tab) {
            tab.addEventListener("click", function () {
                var target = document.querySelector(this.getAttribute("data-bs-target"));
                if (target) target.scrollIntoView({ behavior: "smooth", block: "nearest" });
            });
        });
        document.getElementById("btn-heart").addEventListener("click", function () {
            var icon = document.getElementById("icon-heart");
            icon.classList.toggle("bi-heart");
            icon.classList.toggle("bi-heart-fill");
        });
    </script>
}
