@model IEnumerable<WebBanHang.Models.Publisher>
@await Html.PartialAsync("_CustomerSubnav", "publishers")

<div class="c-browse-page">
    <header class="c-page-head">
        <div>
            <h1 class="c-page-head__title"><i class="bi bi-building me-2"></i>Nhà xuất bản</h1>
            <p class="c-page-head__sub">Danh sách NXB</p>
        </div>
        <a class="c-btn-ghost" href="@Url.RouteUrl("customerPublisherBrowser", new { action = "Index" })">
            <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
        </a>
    </header>

    <div class="c-tiles">
        @if (Model != null && Model.Any())
        {
            @foreach (var p in Model)
            {
                <a class="c-tile c-tile--center" asp-area="Customer" asp-controller="Publishers" asp-action="Details" asp-route-id="@p.Id">
                    @if (!string.IsNullOrEmpty(p.LogoUrl))
                    {
                        <div class="c-tile__media c-tile__media--logo">
                            <img src="@p.LogoUrl" alt="" loading="lazy" />
                        </div>
                    }
                    else
                    {
                        <div class="c-tile__media c-tile__media--icon"><i class="bi bi-building fs-1"></i></div>
                    }
                    <h3>@p.Name</h3>
                </a>
            }
        }
        else
        {
            <div class="c-empty">Không có nhà xuất bản nào.</div>
        }
    </div>

    <div class="mt-4">
        @await Html.PartialAsync("_Pagination")
    </div>
</div>
