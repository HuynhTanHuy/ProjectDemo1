@model WebBanHang.Models.Publisher
@await Html.PartialAsync("_CustomerSubnav", "publishers")

<div class="c-browse-page">
    <div class="c-toolbar mb-3" style="justify-content: flex-start;">
        <a class="c-btn-ghost" href="@Url.RouteUrl("customerPublisherBrowser", new { action = "Index" })">
            <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách nhà xuất bản
        </a>
    </div>

    <header class="c-page-head c-page-head--row">
        @if (!string.IsNullOrEmpty(Model.LogoUrl))
        {
            <img src="@Model.LogoUrl" alt="" class="c-page-head__logo" />
        }
        <div>
            <h1 class="c-page-head__title">@Model.Name</h1>
            @if (!string.IsNullOrEmpty(Model.Website))
            {
                <p class="c-page-head__sub mb-0"><a href="@Model.Website" target="_blank" rel="noopener">Website NXB</a></p>
            }
        </div>
    </header>

    <h2 class="c-section-title">Sách của nhà xuất bản</h2>
    <div class="row g-3">
        @if (Model.Products != null && Model.Products.Any())
        {
            foreach (var p in Model.Products)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    @await Html.PartialAsync("~/Areas/Customer/Views/Product/_ProductCard.cshtml", p)
                </div>
            }
        }
        else
        {
            <div class="col-12 c-empty">Chưa có sách.</div>
        }
    </div>
</div>
