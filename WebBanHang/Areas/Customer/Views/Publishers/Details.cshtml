@model WebBanHang.Models.Publisher

<div class="container mt-4">
    <div class="mb-3">
        <a asp-area="Customer" asp-controller="Home" asp-action="Index" asp-route-tab="publishers" asp-route-page="1" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách nhà xuất bản
        </a>
    </div>
    
    <div class="d-flex align-items-center mb-4">
        @if (!string.IsNullOrEmpty(Model.LogoUrl))
        {
            <img src="@Model.LogoUrl" alt="@Model.Name" class="me-3" style="max-height:60px;object-fit:contain;">
        }
        <div>
            <h3 class="mb-1">@Model.Name</h3>
            @if (!string.IsNullOrEmpty(Model.Website))
            {
                <a href="@Model.Website" target="_blank">Website</a>
            }
        </div>
    </div>

    <h5 class="mb-3">Sách của nhà xuất bản</h5>
    <div class="row">
        @if (Model.Products != null && Model.Products.Any())
        {
            foreach (var p in Model.Products)
            {
                <div class="col-6 col-md-4 col-lg-3 mb-4">
                    @await Html.PartialAsync("~/Areas/Customer/Views/Product/_ProductCard.cshtml", p)
                </div>
            }
        }
        else
        {
            <div class="text-muted">Chưa có sách.</div>
        }
    </div>
</div>



