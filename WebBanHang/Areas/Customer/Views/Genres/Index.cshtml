@model IEnumerable<WebBanHang.Models.Genre>
@await Html.PartialAsync("_CustomerSubnav", "genres")

<div class="c-browse-page">
    <header class="c-page-head">
        <div>
            <h1 class="c-page-head__title"><i class="bi bi-tags me-2"></i>Thể loại</h1>
            <p class="c-page-head__sub">Phân loại theo thể loại sách</p>
        </div>
        <a class="c-btn-ghost" href="@Url.RouteUrl("customerCategoryBrowser", new { action = "Index" })">
            <i class="bi bi-arrow-clockwise me-1"></i>Làm mới
        </a>
    </header>

    <div class="c-tiles">
        @if (Model != null && Model.Any())
        {
            @foreach (var g in Model)
            {
                <a class="c-tile c-tile--center" asp-area="Customer" asp-controller="Genres" asp-action="Details" asp-route-id="@g.Id">
                    <div class="c-tile__media c-tile__media--icon text-primary"><i class="bi bi-tag-fill fs-3"></i></div>
                    <h3>@g.Name</h3>
                </a>
            }
        }
        else
        {
            <div class="c-empty">Không có thể loại nào.</div>
        }
    </div>

    <div class="mt-4">
        @await Html.PartialAsync("_Pagination")
    </div>
</div>
