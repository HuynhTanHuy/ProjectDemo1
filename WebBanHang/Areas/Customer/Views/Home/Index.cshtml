@using System.Globalization
@{
	ViewData["Title"] = "Trang chủ";
	var currentTab = ViewBag.Tab?.ToString() ?? "products";
}

<div class="container bookstore-page py-4">
	<div class="bookstore-shell mx-auto">
	<div class="row align-items-end mb-4">
		<div class="col-12 col-lg-8 mb-3 mb-lg-0">
			<h2 class="display-title mb-0">
				<i class="bi bi-book-half"></i>&nbsp;Nha sach truc tuyen
			</h2>
			<div class="text-secondary small">Kham pha sach moi, doc thu va dat muon nhanh chong</div>
		</div>
		<div class="col-12 col-lg-4">
			<div class="d-flex gap-2 align-items-end">
				@if (currentTab == "products")
				{
					<form method="get" class="d-flex gap-2 flex-grow-1">
						<input type="hidden" name="tab" value="products" />
						<input type="hidden" name="page" value="1" />
						<input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="Tìm kiếm...">
						<button class="btn btn-primary" type="submit"><i class="bi bi-search"></i></button>
					</form>
					<a asp-action="Index" asp-route-tab="products" asp-route-page="1"
					   class="btn btn-outline-secondary" title="Làm mới và quay về trang chủ">
						<i class="bi bi-arrow-clockwise"></i> Làm mới
					</a>
				}				
			</div>
		</div>
	</div>

	<ul class="nav nav-tabs bookstore-tabs mb-4" role="tablist">
		<li class="nav-item" role="presentation">
			<a class="nav-link @(currentTab == "products" ? "active" : "")" 
			   asp-action="Index" asp-route-tab="products" asp-route-page="1">
				<i class="bi bi-book me-2"></i>Sản phẩm
			</a>
		</li>
		<li class="nav-item" role="presentation">
			<a class="nav-link @(currentTab == "authors" ? "active" : "")" 
			   asp-action="Index" asp-route-tab="authors" asp-route-page="1">
				<i class="bi bi-people me-2"></i>Tác giả
			</a>
		</li>
		<li class="nav-item" role="presentation">
			<a class="nav-link @(currentTab == "genres" ? "active" : "")" 
			   asp-action="Index" asp-route-tab="genres" asp-route-page="1">
				<i class="bi bi-tags me-2"></i>Thể loại
			</a>
		</li>
		<li class="nav-item" role="presentation">
			<a class="nav-link @(currentTab == "publishers" ? "active" : "")" 
			   asp-action="Index" asp-route-tab="publishers" asp-route-page="1">
				<i class="bi bi-building me-2"></i>Nhà xuất bản
			</a>
		</li>
	</ul>

	<div class="tab-content">
		@if (currentTab == "products")
		{
			<div class="tab-pane fade show active">
				<form method="get" class="row g-3 mb-4 filter-panel">
					<input type="hidden" name="tab" value="products" />
					<input type="hidden" name="page" value="1" />
					<input type="hidden" name="q" value="@ViewBag.Query" />
					<div class="col-12 col-md-3">
						<label class="form-label small text-muted mb-1">Danh muc</label>
						<select name="categoryId" class="form-select" onchange="this.form.submit()">
							<option value="">Tất cả danh mục</option>
							@foreach (var c in (IEnumerable<WebBanHang.Models.Category>)ViewBag.Categories)
							{
								<option value="@c.Id" selected="@(ViewBag.SelectedCategoryId == c.Id)">@c.Name</option>
							}
						</select>
					</div>
					<div class="col-12 col-md-3">
						<label class="form-label small text-muted mb-1">Tac gia</label>
						<select name="authorId" class="form-select" onchange="this.form.submit()">
							<option value="">Tất cả tác giả</option>
							@foreach (var a in (IEnumerable<WebBanHang.Models.Author>)ViewBag.Authors)
							{
								<option value="@a.Id" selected="@(ViewBag.SelectedAuthorId == a.Id)">@a.Name</option>
							}
						</select>
					</div>
					<div class="col-12 col-md-3">
						<label class="form-label small text-muted mb-1">The loai</label>
						<select name="genreId" class="form-select" onchange="this.form.submit()">
							<option value="">Tất cả thể loại</option>
							@foreach (var g in (IEnumerable<WebBanHang.Models.Genre>)ViewBag.Genres)
							{
								<option value="@g.Id" selected="@(ViewBag.SelectedGenreId == g.Id)">@g.Name</option>
							}
						</select>
					</div>
					<div class="col-12 col-md-3">
						<label class="form-label small text-muted mb-1">Nha xuat ban</label>
						<select name="publisherId" class="form-select" onchange="this.form.submit()">
							<option value="">Tất cả nhà XB</option>
							@foreach (var p in (IEnumerable<WebBanHang.Models.Publisher>)ViewBag.Publishers)
							{
								<option value="@p.Id" selected="@(ViewBag.SelectedPublisherId == p.Id)">@p.Name</option>
							}
						</select>
					</div>
				</form>

				<div class="row g-4" id="productGrid">
					@if (ViewBag.Products != null && ((IEnumerable<WebBanHang.Models.Product>)ViewBag.Products).Any())
					{
						@foreach (var product in (IEnumerable<WebBanHang.Models.Product>)ViewBag.Products)
						{
							<div class="col-12 col-sm-6 col-lg-4 col-xl-3 product-item">
								<div class="card book-card h-100 border-0">
									<div class="position-relative cover-wrap">
										@if (!string.IsNullOrEmpty(product.ImageUrl))
										{
											<img src="@product.ImageUrl" class="card-img-top book-cover" alt="@product.Name">
										}
										else
										{
											<img src="/images/no-image.jpg" class="card-img-top book-cover" alt="No Image">
										}
										<div class="position-absolute top-0 end-0 m-2 d-flex flex-column gap-2">
											@if (product.DiscountPercent.HasValue && product.DiscountPercent.Value > 0)
											{
												<span class="badge rounded-pill bg-danger px-3 py-2">-@product.DiscountPercent%</span>
											}
											@if (product.Category != null)
											{
												<span class="badge rounded-pill text-bg-light border">@product.Category.Name</span>
											}
										</div>
										<div class="position-absolute bottom-0 start-0 p-2">
											@if (product.Stock > 0)
											{
												<span class="badge rounded-pill bg-success">Available</span>
											}
											else
											{
												<span class="badge rounded-pill bg-danger">Out of stock</span>
											}
										</div>
									</div>
									<div class="card-body d-flex flex-column px-3 pb-3">
										<h5 class="book-title mb-2">@product.Name</h5>
										<div class="book-author mb-1">@(!string.IsNullOrWhiteSpace(product.Author?.Name) ? product.Author.Name : "Dang cap nhat tac gia")</div>
										<div class="book-meta mb-3">@product.Genre?.Name · @product.Language</div>
										<div class="mt-auto">
											<div class="mb-3">
												@if (product.DiscountPercent > 0)
												{
													var oldPrice = product.Price;
													var newPrice = product.Price * (100 - product.DiscountPercent) / 100;

													<span class="text-muted text-decoration-line-through me-2 small">
														@oldPrice.ToString("c", new CultureInfo("vi-VN"))
													</span>

													<span class="text-danger fw-bold fs-5">
														@newPrice?.ToString("c", new CultureInfo("vi-VN"))
													</span>
												}
												else
												{
													<span class="text-danger fw-bold fs-5">
														@product.Price.ToString("c", new CultureInfo("vi-VN"))
													</span>
												}
											</div>
											<div class="d-flex gap-2 flex-wrap">
												<a asp-area="" asp-controller="BookPreview"
												   asp-action="View"
												   asp-route-bookId="@product.Id"
												   class="btn btn-primary btn-action">
													<i class="bi bi-book me-1"></i> Preview
												</a>
												<a asp-area="Customer" asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@product.Id" asp-route-quantity="1" class="btn btn-success btn-action @(product.Stock <= 0 ? "disabled" : "")">
													<i class="bi bi-journal-check me-1"></i> Borrow
												</a>
												<a asp-area="Customer" asp-controller="Product" asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-secondary btn-action">
													<i class="bi bi-eye me-1"></i> Detail
												</a>
											</div>
										</div>
									</div>
								</div>
							</div>
						}
					}
					else
					{
						<div class="col-12">
							<div class="alert alert-info text-center">
								<i class="bi bi-info-circle me-2"></i>Không tìm thấy sản phẩm nào.
							</div>
						</div>
					}
				</div>
				
				<div class="mt-4">
					@await Html.PartialAsync("_Pagination")
				</div>
			</div>
		}
		else if (currentTab == "authors")
		{
			<div class="tab-pane fade show active">
				<div class="row">
					@if (ViewBag.AuthorsList != null && ((IEnumerable<WebBanHang.Models.Author>)ViewBag.AuthorsList).Any())
					{
						@foreach (var author in (IEnumerable<WebBanHang.Models.Author>)ViewBag.AuthorsList)
						{
							<div class="col-6 col-md-4 col-lg-3 mb-4">
								<a class="text-decoration-none" asp-area="Customer" asp-controller="Authors" asp-action="Details" asp-route-id="@author.Id">
									<div class="card h-100">
										@if (!string.IsNullOrEmpty(author.PhotoUrl))
										{
											<img src="@author.PhotoUrl" class="card-img-top" alt="@author.Name" style="height:200px;object-fit:cover;">
										}
										else
										{
											<div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:200px;">
												<i class="bi bi-person-circle fs-1 text-muted"></i>
											</div>
										}
										<div class="card-body">
											<h5 class="card-title">@author.Name</h5>
											@if (!string.IsNullOrEmpty(author.Biography))
											{
												<div class="text-muted small text-truncate">@author.Biography</div>
											}
										</div>
									</div>
								</a>
							</div>
						}
					}
					else
					{
						<div class="col-12">
							<div class="alert alert-info text-center">
								<i class="bi bi-info-circle me-2"></i>Không có tác giả nào.
							</div>
						</div>
					}
				</div>
				
				<div class="mt-4">
					@await Html.PartialAsync("_Pagination")
				</div>
			</div>
		}
		else if (currentTab == "genres")
		{
			<div class="tab-pane fade show active">
				<div class="row">
					@if (ViewBag.GenresList != null && ((IEnumerable<WebBanHang.Models.Genre>)ViewBag.GenresList).Any())
					{
						@foreach (var genre in (IEnumerable<WebBanHang.Models.Genre>)ViewBag.GenresList)
						{
							<div class="col-6 col-md-4 col-lg-3 mb-3">
								<a asp-area="Customer" asp-controller="Genres" asp-action="Details" asp-route-id="@genre.Id" class="btn btn-outline-primary w-100">
									<i class="bi bi-tag me-2"></i>@genre.Name
								</a>
							</div>
						}
					}
					else
					{
						<div class="col-12">
							<div class="alert alert-info text-center">
								<i class="bi bi-info-circle me-2"></i>Không có thể loại nào.
							</div>
						</div>
					}
				</div>
				
				<div class="mt-4">
					@await Html.PartialAsync("_Pagination")
				</div>
			</div>
		}
		else if (currentTab == "publishers")
		{
			<div class="tab-pane fade show active">
				<div class="row">
					@if (ViewBag.PublishersList != null && ((IEnumerable<WebBanHang.Models.Publisher>)ViewBag.PublishersList).Any())
					{
						@foreach (var publisher in (IEnumerable<WebBanHang.Models.Publisher>)ViewBag.PublishersList)
						{
							<div class="col-6 col-md-4 col-lg-3 mb-4">
								<a class="text-decoration-none" asp-area="Customer" asp-controller="Publishers" asp-action="Details" asp-route-id="@publisher.Id">
									<div class="card h-100 d-flex align-items-center justify-content-center p-4">
										@if (!string.IsNullOrEmpty(publisher.LogoUrl))
										{
											<img src="@publisher.LogoUrl" alt="@publisher.Name" style="max-height:60px;object-fit:contain;" />
										}
										else
										{
											<i class="bi bi-building fs-1 text-muted"></i>
										}
										<div class="mt-2 fw-semibold">@publisher.Name</div>
									</div>
								</a>
							</div>
						}
					}
					else
					{
						<div class="col-12">
							<div class="alert alert-info text-center">
								<i class="bi bi-info-circle me-2"></i>Không có nhà xuất bản nào.
							</div>
						</div>
					}
				</div>
				
				<div class="mt-4">
					@await Html.PartialAsync("_Pagination")
				</div>
			</div>
		}
	</div>
	</div>
</div>

<style>
	.bookstore-page {
		background: linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
		min-height: 100vh;
	}

	.bookstore-shell {
		max-width: 1320px;
	}

	.display-title {
		font-size: 1.9rem;
		font-weight: 800;
		color: #1e3a8a;
		letter-spacing: .2px;
	}

	.bookstore-tabs .nav-link {
		border: none;
		border-radius: 999px;
		padding: .6rem 1rem;
		color: #475569;
		font-weight: 600;
	}

	.bookstore-tabs .nav-link.active {
		background: #1d4ed8;
		color: #fff;
		box-shadow: 0 8px 18px rgba(29, 78, 216, .25);
	}

	.filter-panel {
		background: #fff;
		border-radius: 16px;
		padding: 1rem;
		box-shadow: 0 10px 24px rgba(15, 23, 42, .06);
	}

	.book-card {
		border-radius: 18px;
		overflow: hidden;
		background: #fff;
		box-shadow: 0 8px 22px rgba(15, 23, 42, .08);
		transition: transform .25s ease, box-shadow .25s ease;
	}

	.book-card:hover {
		transform: translateY(-6px) scale(1.01);
		box-shadow: 0 18px 34px rgba(15, 23, 42, .16);
	}

	.cover-wrap {
		background: #f8fafc;
	}

	.book-cover {
		height: 290px;
		width: 100%;
		object-fit: cover;
	}

	.book-title {
		font-weight: 700;
		color: #0f172a;
		line-height: 1.4;
		min-height: 3rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.book-author {
		color: #334155;
		font-weight: 600;
		font-size: .95rem;
	}

	.book-meta {
		color: #64748b;
		font-size: .85rem;
	}

	.btn-action {
		border-radius: 999px;
		font-weight: 600;
		padding: .45rem .95rem;
		font-size: .85rem;
	}

	@@media (max-width: 575.98px) {
		.display-title {
			font-size: 1.45rem;
		}

		.book-cover {
			height: 250px;
		}
	}
</style>

@section Scripts {
	<script>
		$(document).ready(function() {
			// Chỉ chạy logic reload nếu thực sự là reload (F5), không phải khi click link
			var navEntry = performance.getEntriesByType('navigation')[0];
			var isReload = navEntry && navEntry.type === 'reload';
			
			if (isReload) {
				var urlParams = new URLSearchParams(window.location.search);
				var hasFilters = urlParams.has('q') || urlParams.has('categoryId') || 
								urlParams.has('authorId') || urlParams.has('genreId') || 
								urlParams.has('publisherId');
				var currentPage = parseInt(urlParams.get('page')) || 1;
				var currentTab = urlParams.get('tab') || 'products';
				
				// Nếu reload và có filter/page khác 1/tab khác products, thì reset về trang ban đầu
				if (hasFilters || currentPage > 1 || currentTab !== 'products') {
					window.location.href = '@Url.Action("Index", "Home", new { area = "Customer", tab = "products", page = 1 })';
					return;
				}
			}
			
			if ('@currentTab' === 'products') {
				$("#searchInput").on("keyup", function() {
					var value = $(this).val().toLowerCase();
					$(".product-item").filter(function() {
						$(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
					});
				});
			}
		});
	</script>
}
