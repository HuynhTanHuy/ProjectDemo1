@model WebBanHang.Models.ViewModels.CustomerHomeIndexViewModel
@functions {
    private static RouteValueDictionary CatalogRoute(CustomerHomeIndexViewModel m, object? overrides = null)
    {
        var d = new RouteValueDictionary
        {
            ["area"] = "Customer",
            ["controller"] = "Home",
            ["action"] = "Index",
            ["tab"] = "products",
            ["page"] = m.CurrentPage,
            ["pageSize"] = m.PageSize,
            ["sort"] = m.Sort,
        };
        if (!string.IsNullOrWhiteSpace(m.Query))
        {
            d["keyword"] = m.Query;
        }

        if (m.CategoryId is > 0)
        {
            d["categoryId"] = m.CategoryId;
        }

        if (m.AuthorId is > 0)
        {
            d["authorId"] = m.AuthorId;
        }

        if (m.GenreId is > 0)
        {
            d["genreId"] = m.GenreId;
        }

        if (m.PublisherId is > 0)
        {
            d["publisherId"] = m.PublisherId;
        }

        if (!string.IsNullOrWhiteSpace(m.Status))
        {
            d["status"] = m.Status;
        }

        if (m.MinRating is >= 1 and <= 5)
        {
            d["minRating"] = m.MinRating;
        }

        if (m.YearFrom is > 0)
        {
            d["yearFrom"] = m.YearFrom;
        }

        if (m.YearTo is > 0)
        {
            d["yearTo"] = m.YearTo;
        }

        if (!string.IsNullOrWhiteSpace(m.Lang))
        {
            d["lang"] = m.Lang;
        }

        if (overrides != null)
        {
            foreach (var kv in new RouteValueDictionary(overrides))
            {
                if (kv.Value == null)
                {
                    d.Remove(kv.Key);
                }
                else
                {
                    d[kv.Key] = kv.Value;
                }
            }
        }

        return d;
    }
}

@await Html.PartialAsync("_CustomerSubnav", Model.Tab)

@if (Model.Tab == "products" && Model.Catalog != null)
{
    var cat = Model.Catalog;
    var st = cat.Status ?? "";

    var totalBooks = Math.Max(1, cat.StatTotalBooks);
    var pctAvail = 100.0 * cat.StatAvailableTitles / totalBooks;
    var pctBorrow = 100.0 * cat.StatBorrowing / totalBooks;
    var pctOverdueOfBorrow = cat.StatBorrowing > 0 ? 100.0 * cat.StatOverdueLoans / cat.StatBorrowing : 0;

    <div class="c-dash-grid">
        <div class="c-dash-card c-dash-card--blue">
            <div class="c-dash-card__icon"><i class="bi bi-journal-richtext"></i></div>
            <div class="c-dash-card__body">
                <div class="c-dash-card__value">@cat.StatTotalBooks.ToString("N0")</div>
                <div class="c-dash-card__label">Tổng sách</div>
                <div class="c-dash-card__hint">100% danh mục</div>
            </div>
        </div>
        <div class="c-dash-card c-dash-card--green">
            <div class="c-dash-card__icon"><i class="bi bi-bookmark-check"></i></div>
            <div class="c-dash-card__body">
                <div class="c-dash-card__value">@cat.StatAvailableTitles.ToString("N0")</div>
                <div class="c-dash-card__label">Còn sách (sẵn có)</div>
                <div class="c-dash-card__hint">@pctAvail.ToString("0.#")% / tổng đầu sách</div>
            </div>
        </div>
        <div class="c-dash-card c-dash-card--amber">
            <div class="c-dash-card__icon"><i class="bi bi-people"></i></div>
            <div class="c-dash-card__body">
                <div class="c-dash-card__value">@cat.StatBorrowing.ToString("N0")</div>
                <div class="c-dash-card__label">Đang mượn</div>
                <div class="c-dash-card__hint">@pctBorrow.ToString("0.#")% / tổng đầu sách</div>
            </div>
        </div>
        <div class="c-dash-card c-dash-card--red">
            <div class="c-dash-card__icon"><i class="bi bi-exclamation-triangle"></i></div>
            <div class="c-dash-card__body">
                <div class="c-dash-card__value">@cat.StatOverdueLoans.ToString("N0")</div>
                <div class="c-dash-card__label">Quá hạn</div>
                <div class="c-dash-card__hint">@pctOverdueOfBorrow.ToString("0.#")% / lượt đang mượn</div>
            </div>
        </div>
    </div>

    <nav class="c-catnav" aria-label="Danh mục">
        <a class="c-catnav__link @(Model.CategoryId == null || Model.CategoryId == 0 ? "is-active" : null)"
           href="@Url.Action("Index", "Home", CatalogRoute(Model, new { categoryId = (int?)null, page = 1 }))">Tất cả</a>
        @foreach (var c in (IEnumerable<WebBanHang.Models.Category>)ViewBag.Categories)
        {
            <a class="c-catnav__link @(Model.CategoryId == c.Id ? "is-active" : null)"
               href="@Url.Action("Index", "Home", CatalogRoute(Model, new { categoryId = c.Id, page = 1 }))">@c.Name</a>
        }
    </nav>

    <div class="c-layout">
        <aside class="c-sidebar" aria-label="Bộ lọc">
            <form method="get" action="@Url.Action("Index", "Home", new { area = "Customer" })">
                <input type="hidden" name="tab" value="products" />
                <input type="hidden" name="page" value="1" />
                <input type="hidden" name="sort" value="@Model.Sort" />
                <input type="hidden" name="keyword" value="@Model.Query" />
                @if (Model.CategoryId is > 0)
                {
                    <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                }

                <p class="c-sidebar__title">Trạng thái</p>
                <div class="c-field">
                    <select name="status" aria-label="Trạng thái">
                        @if (st == "")
                        {
                            <option value="" selected="selected">Tất cả</option>
                        }
                        else
                        {
                            <option value="">Tất cả</option>
                        }
                        @if (st == "available")
                        {
                            <option value="available" selected="selected">Sẵn có</option>
                        }
                        else
                        {
                            <option value="available">Sẵn có</option>
                        }
                        @if (st == "borrowing")
                        {
                            <option value="borrowing" selected="selected">Đang mượn</option>
                        }
                        else
                        {
                            <option value="borrowing">Đang mượn</option>
                        }
                        @if (st == "overdue")
                        {
                            <option value="overdue" selected="selected">Quá hạn</option>
                        }
                        else
                        {
                            <option value="overdue">Quá hạn</option>
                        }
                        @if (st == "out")
                        {
                            <option value="out" selected="selected">Hết sách</option>
                        }
                        else
                        {
                            <option value="out">Hết sách</option>
                        }
                    </select>
                </div>

                <p class="c-sidebar__title">Đánh giá tối thiểu</p>
                <div class="c-field">
                    <select name="minRating" aria-label="Đánh giá">
                        @if (!Model.MinRating.HasValue)
                        {
                            <option value="" selected="selected">Bất kỳ</option>
                        }
                        else
                        {
                            <option value="">Bất kỳ</option>
                        }
                        @if (Model.MinRating == 1)
                        {
                            <option value="1" selected="selected">Từ 1 ★</option>
                        }
                        else
                        {
                            <option value="1">Từ 1 ★</option>
                        }
                        @if (Model.MinRating == 2)
                        {
                            <option value="2" selected="selected">Từ 2 ★</option>
                        }
                        else
                        {
                            <option value="2">Từ 2 ★</option>
                        }
                        @if (Model.MinRating == 3)
                        {
                            <option value="3" selected="selected">Từ 3 ★</option>
                        }
                        else
                        {
                            <option value="3">Từ 3 ★</option>
                        }
                        @if (Model.MinRating == 4)
                        {
                            <option value="4" selected="selected">Từ 4 ★</option>
                        }
                        else
                        {
                            <option value="4">Từ 4 ★</option>
                        }
                        @if (Model.MinRating == 5)
                        {
                            <option value="5" selected="selected">5 ★</option>
                        }
                        else
                        {
                            <option value="5">5 ★</option>
                        }
                    </select>
                </div>

                <p class="c-sidebar__title">Năm xuất bản</p>
                <div class="c-field">
                    <label for="yf">Từ</label>
                    <input id="yf" type="number" name="yearFrom" value="@Model.YearFrom" min="1800" max="2100" placeholder="VD: 2010" />
                </div>
                <div class="c-field">
                    <label for="yt">Đến</label>
                    <input id="yt" type="number" name="yearTo" value="@Model.YearTo" min="1800" max="2100" placeholder="VD: 2024" />
                </div>

                <p class="c-sidebar__title">Ngôn ngữ</p>
                <div class="c-field">
                    <select name="lang" aria-label="Ngôn ngữ">
                        @if (string.IsNullOrEmpty(Model.Lang))
                        {
                            <option value="" selected="selected">Tất cả</option>
                        }
                        else
                        {
                            <option value="">Tất cả</option>
                        }
                        @foreach (var lng in (ViewBag.Languages as IEnumerable<string>) ?? Array.Empty<string>())
                        {
                            if (Model.Lang == lng)
                            {
                                <option value="@lng" selected="selected">@lng</option>
                            }
                            else
                            {
                                <option value="@lng">@lng</option>
                            }
                        }
                    </select>
                </div>

                <p class="c-sidebar__title">Thể loại</p>
                <div class="c-field">
                    <select name="genreId" aria-label="Thể loại">
                        @foreach (var opt in cat.GenreOptions)
                        {
                            if (opt.Selected)
                            {
                                <option value="@opt.Value" selected="selected">@opt.Text</option>
                            }
                            else
                            {
                                <option value="@opt.Value">@opt.Text</option>
                            }
                        }
                    </select>
                </div>

                <p class="c-sidebar__title">Tác giả</p>
                <div class="c-field">
                    <select name="authorId" aria-label="Tác giả">
                        <option value="">Tất cả</option>
                        @foreach (var a in (IEnumerable<WebBanHang.Models.Author>)ViewBag.Authors)
                        {
                            if (Model.AuthorId == a.Id)
                            {
                                <option value="@a.Id" selected="selected">@a.Name</option>
                            }
                            else
                            {
                                <option value="@a.Id">@a.Name</option>
                            }
                        }
                    </select>
                </div>

                <p class="c-sidebar__title">Nhà xuất bản</p>
                <div class="c-field">
                    <select name="publisherId" aria-label="NXB">
                        <option value="">Tất cả</option>
                        @foreach (var p in (IEnumerable<WebBanHang.Models.Publisher>)ViewBag.Publishers)
                        {
                            if (Model.PublisherId == p.Id)
                            {
                                <option value="@p.Id" selected="selected">@p.Name</option>
                            }
                            else
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        }
                    </select>
                </div>

                <input type="hidden" name="pageSize" value="@Model.PageSize" />
                <button type="submit" class="c-btn-apply">Áp dụng</button>
            </form>
        </aside>

        <div class="c-content">
            <div class="c-toolbar">
                <div class="c-sort" role="group" aria-label="Sắp xếp">
                    <a class="c-sort__link @(Model.Sort == "popular" ? "is-active" : null)"
                       href="@Url.Action("Index", "Home", CatalogRoute(Model, new { sort = "popular", page = 1 }))">Phổ biến</a>
                    <a class="c-sort__link @(Model.Sort == "newest" ? "is-active" : null)"
                       href="@Url.Action("Index", "Home", CatalogRoute(Model, new { sort = "newest", page = 1 }))">Mới nhất</a>
                    <a class="c-sort__link @(Model.Sort == "az" ? "is-active" : null)"
                       href="@Url.Action("Index", "Home", CatalogRoute(Model, new { sort = "az", page = 1 }))">A-Z</a>
                </div>
                <div class="c-meta">
                    <span>@cat.TotalFilteredCount.ToString("N0") kết quả</span>
                    <form method="get" action="@Url.Action("Index", "Home", new { area = "Customer" })" class="d-flex align-items-center gap-1">
                        <input type="hidden" name="tab" value="products" />
                        <input type="hidden" name="page" value="1" />
                        <input type="hidden" name="sort" value="@Model.Sort" />
                        <input type="hidden" name="status" value="@st" />
                        @if (Model.MinRating.HasValue)
                        {
                            <input type="hidden" name="minRating" value="@Model.MinRating.Value" />
                        }
                        @if (Model.YearFrom.HasValue)
                        {
                            <input type="hidden" name="yearFrom" value="@Model.YearFrom.Value" />
                        }
                        @if (Model.YearTo.HasValue)
                        {
                            <input type="hidden" name="yearTo" value="@Model.YearTo.Value" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Lang))
                        {
                            <input type="hidden" name="lang" value="@Model.Lang" />
                        }
                        @if (Model.CategoryId is > 0)
                        {
                            <input type="hidden" name="categoryId" value="@Model.CategoryId" />
                        }
                        @if (Model.AuthorId is > 0)
                        {
                            <input type="hidden" name="authorId" value="@Model.AuthorId" />
                        }
                        @if (Model.GenreId is > 0)
                        {
                            <input type="hidden" name="genreId" value="@Model.GenreId" />
                        }
                        @if (Model.PublisherId is > 0)
                        {
                            <input type="hidden" name="publisherId" value="@Model.PublisherId" />
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.Query))
                        {
                            <input type="hidden" name="keyword" value="@Model.Query" />
                        }
                        <label class="mb-0" for="pageSizeSel">Hiển thị</label>
                        <select id="pageSizeSel" name="pageSize" onchange="this.form.submit()">
                            @foreach (var n in new[] { 12, 24, 48 })
                            {
                                if (Model.PageSize == n)
                                {
                                    <option value="@n" selected="selected">@n / trang</option>
                                }
                                else
                                {
                                    <option value="@n">@n / trang</option>
                                }
                            }
                        </select>
                    </form>
                </div>
            </div>

            <div class="c-grid">
                @if (!cat.Books.Any())
                {
                    <div class="c-empty">Không có sách phù hợp bộ lọc.</div>
                }
                else
                {
                    @foreach (var item in cat.Books)
                    {
                        var pill = item.StatusKey switch
                        {
                            "available" => "c-pill--available",
                            "borrowing" => "c-pill--borrowing",
                            "overdue" => "c-pill--overdue",
                            _ => "c-pill--out"
                        };
                        string? thumbSrc = null;
                        if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                        {
                            var path = item.ImageUrl.Trim().Replace("\\", "/").TrimStart('~', '/');
                            thumbSrc = Url.Content("~/" + path);
                        }
                        <article class="c-card">
                            <a class="c-card__thumb-wrap" asp-area="Customer" asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">
                                @if (thumbSrc != null)
                                {
                                    <img class="c-card__thumb" src="@thumbSrc" alt="" loading="lazy" />
                                }
                                else
                                {
                                    <div class="c-card__thumb c-card__thumb--ph" aria-hidden="true">📖</div>
                                }
                            </a>
                            <div class="c-card__body">
                                <a asp-area="Customer" asp-controller="Product" asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">
                                    <h3 class="c-card__title">@item.Name</h3>
                                </a>
                                <p class="c-card__author">@item.Author</p>
                                <div class="c-card__row">
                                    <div class="c-rating">
                                        ★ @item.AvgRating.ToString("0.0")
                                        <span>/ 5</span>
                                    </div>
                                    <span class="c-pill @pill">@item.StatusLabel</span>
                                </div>
                                <div class="c-card__actions@(item.StatusKey == "available" ? " c-card__actions--3" : "")">
                                    @if (item.StatusKey == "available")
                                    {
                                        <a class="c-act--primary" asp-area="Customer" asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">Mượn</a>
                                        <a class="c-act--secondary" asp-area="Customer" asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@item.Id" asp-route-quantity="1">Giỏ</a>
                                        <a class="c-act--detail" asp-area="Customer" asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a>
                                    }
                                    else if (item.StatusKey == "borrowing" || item.StatusKey == "overdue")
                                    {
                                        <a class="c-act--primary" asp-area="Customer" asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-productId="@item.Id" asp-route-quantity="1">Đặt chỗ</a>
                                        <a class="c-act--detail" asp-area="Customer" asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a>
                                    }
                                    else
                                    {
                                        <span class="c-act--wait">Chờ</span>
                                        <a class="c-act--detail" asp-area="Customer" asp-controller="Product" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                }
            </div>

            <div class="mt-3">
                @await Html.PartialAsync("_Pagination")
            </div>
        </div>
    </div>
}
else if (Model.Tab == "authors")
{
    <div class="c-tiles">
        @if (Model.Authors != null && Model.Authors.Any())
        {
            @foreach (var author in Model.Authors)
            {
                <a class="c-tile" asp-area="Customer" asp-controller="Authors" asp-action="Details" asp-route-id="@author.Id">
                    <h3>@author.Name</h3>
                    @if (!string.IsNullOrEmpty(author.Biography))
                    {
                        <p class="text-truncate">@author.Biography</p>
                    }
                </a>
            }
        }
        else
        {
            <div class="c-empty">Chưa có tác giả.</div>
        }
    </div>
    <div class="mt-3">@await Html.PartialAsync("_Pagination")</div>
}
else if (Model.Tab == "genres")
{
    <div class="c-tiles">
        @if (Model.Genres != null && Model.Genres.Any())
        {
            @foreach (var genre in Model.Genres)
            {
                <a class="c-tile" asp-area="Customer" asp-controller="Genres" asp-action="Details" asp-route-id="@genre.Id">
                    <h3>@genre.Name</h3>
                </a>
            }
        }
        else
        {
            <div class="c-empty">Chưa có thể loại.</div>
        }
    </div>
    <div class="mt-3">@await Html.PartialAsync("_Pagination")</div>
}
else if (Model.Tab == "publishers")
{
    <div class="c-tiles">
        @if (Model.Publishers != null && Model.Publishers.Any())
        {
            @foreach (var publisher in Model.Publishers)
            {
                <a class="c-tile" asp-area="Customer" asp-controller="Publishers" asp-action="Details" asp-route-id="@publisher.Id">
                    <h3>@publisher.Name</h3>
                </a>
            }
        }
        else
        {
            <div class="c-empty">Chưa có nhà xuất bản.</div>
        }
    </div>
    <div class="mt-3">@await Html.PartialAsync("_Pagination")</div>
}
