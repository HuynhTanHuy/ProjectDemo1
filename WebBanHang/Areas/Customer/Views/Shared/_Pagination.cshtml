@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalItems = ViewBag.TotalItems ?? 0;
    string? query = ViewBag.Query;
    int? categoryId = ViewBag.SelectedCategoryId;
    int? authorId = ViewBag.SelectedAuthorId;
    int? genreId = ViewBag.SelectedGenreId;
    int? publisherId = ViewBag.SelectedPublisherId;
    string? tab = ViewBag.Tab;
    string? statusFilter = ViewBag.StatusFilter as string;
    string? sort = ViewBag.Sort as string;
    int? minRating = ViewBag.MinRating as int?;
    int? yearFrom = ViewBag.YearFrom as int?;
    int? yearTo = ViewBag.YearTo as int?;
    string? lang = ViewBag.Lang as string;
    int? pageSize = ViewBag.PageSize as int?;
    string areaName = ViewContext.RouteData.Values["area"]?.ToString() ?? "";
    string controllerName = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string actionName = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    string PageHref(int pageNum)
    {
        var r = BuildRoute(pageNum);
        if (string.Equals(areaName, "Customer", StringComparison.OrdinalIgnoreCase)
            && string.Equals(controllerName, "Home", StringComparison.OrdinalIgnoreCase))
        {
            return Url.Action("Index", "Home", r) ?? "#";
        }

        return Url.Action(actionName, controllerName, r) ?? "#";
    }

    var isProductCatalog = string.Equals(controllerName, "Home", StringComparison.OrdinalIgnoreCase)
        && string.Equals(tab?.ToString(), "products", StringComparison.OrdinalIgnoreCase);

    RouteValueDictionary BuildRoute(int pageNum)
    {
        var rv = new RouteValueDictionary
        {
            ["area"] = "Customer",
            ["controller"] = controllerName,
            ["action"] = actionName,
            ["page"] = pageNum
        };

        if (string.Equals(controllerName, "Home", StringComparison.OrdinalIgnoreCase)
            && !string.IsNullOrEmpty(tab?.ToString()))
        {
            rv["tab"] = tab;
        }

        if (isProductCatalog)
        {
            if (!string.IsNullOrWhiteSpace(query)) rv["keyword"] = query;
            if (categoryId is > 0) rv["categoryId"] = categoryId;
            if (authorId is > 0) rv["authorId"] = authorId;
            if (genreId is > 0) rv["genreId"] = genreId;
            if (publisherId is > 0) rv["publisherId"] = publisherId;
            if (!string.IsNullOrWhiteSpace(statusFilter)) rv["status"] = statusFilter;
            if (!string.IsNullOrWhiteSpace(sort)) rv["sort"] = sort;
            if (minRating is >= 1 and <= 5) rv["minRating"] = minRating;
            if (yearFrom is > 0) rv["yearFrom"] = yearFrom;
            if (yearTo is > 0) rv["yearTo"] = yearTo;
            if (!string.IsNullOrWhiteSpace(lang)) rv["lang"] = lang;
            if (pageSize is > 0) rv["pageSize"] = pageSize;
        }
        else if (string.Equals(controllerName, "Product", StringComparison.OrdinalIgnoreCase)
                 || string.Equals(controllerName, "Home", StringComparison.OrdinalIgnoreCase))
        {
            if (!string.IsNullOrWhiteSpace(query)) rv["keyword"] = query;
            if (categoryId is > 0) rv["categoryId"] = categoryId;
            if (authorId is > 0) rv["authorId"] = authorId;
            if (genreId is > 0) rv["genreId"] = genreId;
            if (publisherId is > 0) rv["publisherId"] = publisherId;
        }

        return rv;
    }
}

@if (totalPages > 1)
{
    <nav class="c-pagination" aria-label="Phân trang">
        <ul class="pagination justify-content-center flex-wrap">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@PageHref(currentPage - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                </li>
            }

            @{
                int startPage = Math.Max(1, currentPage - 2);
                int endPage = Math.Min(totalPages, currentPage + 2);
            }

            @if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="@PageHref(1)">1</a>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled">
                        <span class="page-link">…</span>
                    </li>
                }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@PageHref(i)">@i</a>
                </li>
            }

            @if (endPage < totalPages)
            {
                @if (endPage < totalPages - 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">…</span>
                    </li>
                }
                <li class="page-item">
                    <a class="page-link" href="@PageHref(totalPages)">@totalPages</a>
                </li>
            }

            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="@PageHref(currentPage + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                </li>
            }
        </ul>
    </nav>

    <div class="text-center mt-2 small" style="color: var(--muted);">
        Trang @currentPage / @totalPages · @totalItems.ToString("N0") mục
    </div>
}
