@model WebBanHang.Models.Author

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>Xóa Tác giả
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Bạn có chắc chắn muốn xóa tác giả này không? Hành động này không thể hoàn tác.
                    </div>
                    
                    <form method="post">
                        <input asp-for="Id" hidden />
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label">Tên tác giả</label>
                                <input asp-for="Name" disabled class="form-control" />
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Ảnh đại diện</label>
                                @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                                {
                                    <div>
                                        <img src="@Model.PhotoUrl" alt="@Model.Name" style="max-width: 150px; max-height: 150px; border-radius: 5px;" />
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted">Không có ảnh</p>
                                }
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="Biography" class="form-label">Tiểu sử</label>
                            <textarea asp-for="Biography" disabled class="form-control" rows="5">@Model.Biography</textarea>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash-fill me-1"></i>Xóa
                            </button>
                            <a asp-controller="Authors" asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

