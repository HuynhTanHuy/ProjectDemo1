@model WebBanHang.Models.Publisher

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>Xóa Nhà xuất bản
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Bạn có chắc chắn muốn xóa nhà xuất bản này không? Hành động này không thể hoàn tác.
                    </div>
                    
                    <form method="post">
                        <input asp-for="Id" hidden />
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Name" class="form-label">Tên nhà xuất bản</label>
                                <input asp-for="Name" disabled class="form-control" />
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="Website" class="form-label">Website</label>
                                <input asp-for="Website" disabled class="form-control" />
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Logo</label>
                            @if (!string.IsNullOrEmpty(Model.LogoUrl))
                            {
                                <div>
                                    <img src="@Model.LogoUrl" alt="@Model.Name" style="max-width: 150px; max-height: 150px; object-fit: contain;" />
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">Không có logo</p>
                            }
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash-fill me-1"></i>Xóa
                            </button>
                            <a asp-controller="Publishers" asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

