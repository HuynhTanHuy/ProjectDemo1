@model WebBanHang.Models.Genre

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>Xóa Thể loại
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Bạn có chắc chắn muốn xóa thể loại này không? Hành động này không thể hoàn tác.
                    </div>
                    
                    <form method="post">
                        <input asp-for="Id" hidden />
                        
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Tên thể loại</label>
                            <input asp-for="Name" disabled class="form-control" />
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash-fill me-1"></i>Xóa
                            </button>
                            <a asp-controller="Genres" asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

