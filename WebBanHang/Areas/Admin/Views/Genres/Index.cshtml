@model IEnumerable<WebBanHang.Models.Genre>

<div class="container mt-4">
    <div class="row pt-4 pb-3">
        <div class="col-6">
            <h2 class="text-primary">
                <i class="bi bi-tags me-2"></i>Quản lý Thể loại
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Genres" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Thêm Thể loại
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <table class="table table-bordered table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Tên thể loại</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var obj in Model)
                            {
                                <tr>
                                    <td>@obj.Id</td>
                                    <td>@obj.Name</td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-controller="Genres" asp-action="Edit" asp-route-id="@obj.Id"
                                               class="btn btn-primary btn-sm">
                                                <i class="bi bi-pencil-square"></i> Sửa
                                            </a>
                                            <a asp-controller="Genres" asp-action="Delete" asp-route-id="@obj.Id"
                                               class="btn btn-danger btn-sm">
                                                <i class="bi bi-trash-fill"></i> Xóa
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

