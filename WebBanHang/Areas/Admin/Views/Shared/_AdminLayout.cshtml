@using WebBanHang.Models
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="d-flex">
        <aside class="bg-dark text-white p-3" style="width:260px; min-height:100vh;">
            <h5 class="mb-4">Library Admin</h5>
            <a class="btn btn-outline-light btn-sm w-100 mb-3" asp-area="Customer" asp-controller="Home" asp-action="Index" asp-route-tab="products">
                <i class="bi bi-shop me-2"></i>Xem cửa hàng
            </a>
            <ul class="nav flex-column gap-1">
                <li class="nav-item"><a class="nav-link text-white" asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                <li class="nav-item"><a class="nav-link text-white" asp-area="Admin" asp-controller="Product" asp-action="Index"><i class="bi bi-book me-2"></i>Books</a></li>
                <li class="nav-item"><a class="nav-link text-white" asp-area="Admin" asp-controller="Borrows" asp-action="Index"><i class="bi bi-journal-check me-2"></i>Borrows</a></li>
                <li class="nav-item"><a class="nav-link text-white" asp-area="Admin" asp-controller="Orders" asp-action="Index"><i class="bi bi-receipt me-2"></i>Orders</a></li>
                <li class="nav-item"><a class="nav-link text-white" asp-area="Admin" asp-controller="Penalties" asp-action="Index"><i class="bi bi-exclamation-triangle me-2"></i>Penalties</a></li>
            </ul>
        </aside>
        <main class="flex-grow-1 p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
