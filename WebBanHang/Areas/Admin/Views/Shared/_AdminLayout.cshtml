@using WebBanHang.Models
@{
    var nav = ViewData["AdminNavSection"] as string ?? "";
    var pageTitle = ViewData["AdminPageTitle"] as string ?? ViewData["Title"] as string ?? "Quản trị";
    var breadcrumb = ViewData["AdminBreadcrumb"] as string ?? "";
    var notifCount = ViewData["AdminNotifCount"] as int?;
    var userName = User.Identity?.Name ?? "Admin";
    var initial = userName.Length > 0 ? userName.Substring(0, 1).ToUpperInvariant() : "?";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body class="dashboard-body">
    <div class="dashboard-shell">
        <aside class="dashboard-sidebar">
            <a class="dashboard-brand" asp-area="Admin" asp-controller="Home" asp-action="Index">Thư viện</a>

            <nav>
                <div class="dashboard-nav-section">
                    <div class="dashboard-nav-heading">Tổng quan</div>
                    <a class="dashboard-nav-link @(nav == "overview" ? "is-active" : null)" asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid-1x2-fill"></i> Bảng điều khiển
                    </a>
                </div>

                <div class="dashboard-nav-section">
                    <div class="dashboard-nav-heading">Sách</div>
                    <a class="dashboard-nav-link @(nav == "books" ? "is-active" : null)" asp-area="Admin" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-book-half"></i> Danh sách sách
                    </a>
                    <a class="dashboard-nav-link @(nav == "borrows" ? "is-active" : null)" asp-area="Admin" asp-controller="Borrows" asp-action="Index">
                        <i class="bi bi-arrow-left-right"></i> Mượn &amp; trả
                    </a>
                </div>

                <div class="dashboard-nav-section">
                    <div class="dashboard-nav-heading">Thành viên</div>
                    <a class="dashboard-nav-link @(nav == "members" ? "is-active" : null)" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="bi bi-people-fill"></i> Tài khoản
                    </a>
                </div>

                <div class="dashboard-nav-section">
                    <div class="dashboard-nav-heading">Giao dịch</div>
                    <a class="dashboard-nav-link @(nav == "orders" ? "is-active" : null)" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                        <i class="bi bi-bag-check-fill"></i> Đơn hàng
                    </a>
                    <a class="dashboard-nav-link @(nav == "penalties" ? "is-active" : null)" asp-area="Admin" asp-controller="Penalties" asp-action="Index">
                        <i class="bi bi-cash-coin"></i> Phạt &amp; nợ
                    </a>
                </div>
            </nav>

            <div class="dashboard-sidebar-footer">
                <a class="btn btn-outline-light btn-sm w-100" href="@Url.Action("Index", "Home", new { area = "Customer", tab = "products" })">
                    <i class="bi bi-shop-window me-2"></i>Cửa hàng
                </a>
            </div>
        </aside>

        <div class="dashboard-main">
            <header class="dashboard-header">
                <div class="dashboard-header-titles">
                    <h1>@pageTitle</h1>
                    @if (!string.IsNullOrEmpty(breadcrumb))
                    {
                        <p class="dashboard-breadcrumb">@breadcrumb</p>
                    }
                </div>
                <div class="dashboard-header-actions">
                    <button type="button" class="dashboard-icon-btn" title="Thông báo" aria-label="Thông báo">
                        <i class="bi bi-bell"></i>
                        @if (notifCount is > 0)
                        {
                            <span class="badge text-bg-danger rounded-pill">@(notifCount > 99 ? "99+" : notifCount.ToString())</span>
                        }
                    </button>
                    <span class="dashboard-avatar" title="@userName">@initial</span>
                </div>
            </header>

            <main class="dashboard-content">
                @if (TempData["Success"] != null || TempData["success"] != null)
                {
                    <div class="alert alert-success dashboard-alert">@(TempData["Success"] ?? TempData["success"])</div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger dashboard-alert">@TempData["Error"]</div>
                }
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
