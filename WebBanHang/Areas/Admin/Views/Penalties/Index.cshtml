@using System.Globalization
@model IEnumerable<WebBanHang.Models.ViewModels.PenaltyListItemViewModel>
@{
    ViewData["Title"] = "Penalty Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Penalties</h4>
    <div class="text-muted">Total: <strong class="text-danger">@((decimal)ViewBag.TotalAmount).ToString("c", new CultureInfo("vi-VN"))</strong></div>
</div>

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body row g-2 align-items-center">
        <div class="col-md-6">
            <input type="text" name="q" value="@ViewBag.Query" class="form-control" placeholder="Search user, book, reason..." />
        </div>
        <div class="col-md-2">
            <select name="isPaid" class="form-select">
                <option value="">All status</option>
                <option value="false" selected="@(ViewBag.IsPaid is bool b1 && b1 == false)">Unpaid</option>
                <option value="true" selected="@(ViewBag.IsPaid is bool b2 && b2 == true)">Paid</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100" type="submit">Search</button>
        </div>
        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Reset</a>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>User</th>
                    <th>Book</th>
                    <th>Reason</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">No penalties found.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.UserName</td>
                            <td>@item.BookTitle</td>
                            <td><span class="badge bg-warning text-dark">@item.Reason</span></td>
                            <td class="text-danger fw-semibold">@item.Amount.ToString("c", new CultureInfo("vi-VN"))</td>
                            <td>
                                @if (item.IsPaid)
                                {
                                    <span class="badge bg-success">Paid</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Unpaid</span>
                                }
                            </td>
                            <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end">
                                @if (!item.IsPaid)
                                {
                                    <form asp-action="MarkAsPaid" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button class="btn btn-sm btn-outline-success rounded-pill">Mark as Paid</button>
                                    </form>
                                }
                                else if (item.PaidAt.HasValue)
                                {
                                    <span class="text-muted small">Paid at @item.PaidAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if ((int)ViewBag.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination">
            @for (var i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-q="@ViewBag.Query" asp-route-isPaid="@ViewBag.IsPaid">@i</a>
                </li>
            }
        </ul>
    </nav>
}
