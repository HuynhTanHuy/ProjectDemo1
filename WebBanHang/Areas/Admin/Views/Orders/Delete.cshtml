@using System.Globalization
@model WebBanHang.Models.Order

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle me-2"></i>Xóa Đơn hàng #@Model.Id
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Cảnh báo:</strong> Bạn có chắc chắn muốn xóa đơn hàng này không? Hành động này sẽ xóa toàn bộ thông tin đơn hàng và không thể hoàn tác.
                    </div>
                    
                    <form method="post">
                        <input asp-for="Id" hidden />
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h5>Thông tin đơn hàng</h5>
                                <table class="table table-bordered">
                                    <tr>
                                        <th>ID Đơn hàng:</th>
                                        <td>@Model.Id</td>
                                    </tr>
                                    <tr>
                                        <th>Người đặt:</th>
                                        <td>@Model.ApplicationUser?.UserName</td>
                                    </tr>
                                    <tr>
                                        <th>Ngày đặt:</th>
                                        <td>@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                    <tr>
                                        <th>Tổng tiền:</th>
                                        <td class="fw-bold text-danger">@Model.TotalPrice.ToString("c", new CultureInfo("vi-VN"))</td>
                                    </tr>
                                    <tr>
                                        <th>Địa chỉ giao hàng:</th>
                                        <td>@Model.ShippingAddress</td>
                                    </tr>
                                </table>
                            </div>
                            
                            <div class="col-md-6">
                                <h5>Chi tiết sản phẩm</h5>
                                <table class="table table-bordered table-sm">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Sản phẩm</th>
                                            <th>SL</th>
                                            <th>Giá</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach(var detail in Model.OrderDetails)
                                        {
                                            <tr>
                                                <td>@detail.Product?.Name</td>
                                                <td>@detail.Quantity</td>
                                                <td>@detail.Price.ToString("c", new CultureInfo("vi-VN"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash-fill me-1"></i>Xóa
                            </button>
                            <a asp-controller="Orders" asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

